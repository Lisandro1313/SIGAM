// Schema para SIGAM - Sistema Integral de Gestión Alimentaria Municipal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ADMIN                // Políticas Alimentarias - acceso total
  LOGISTICA            // Stock, depósitos, transferencias
  OPERADOR_PROGRAMA    // Beneficiarios, remitos de su programa
  TRABAJADORA_SOCIAL   // Solo relevamiento (observaciones) de beneficiarios
  ASISTENCIA_CRITICA   // Solo sus propios remitos (chapas, materiales, etc.)
  VISOR                // Solo lectura: dashboard y reportes
  CHOFER               // Reparto a domicilio - solo ve sus entregas asignadas
  NUTRICIONISTA        // Nutricionistas que visitan espacios y hacen relevamientos
}

enum MovimientoTipo {
  INGRESO
  EGRESO
  AJUSTE
  TRANSFERENCIA
}

enum EntregaEstado {
  PENDIENTE
  GENERADA
  ENTREGADA
  CANCELADA
}

enum RemitoEstado {
  PREPARADO
  BORRADOR
  CONFIRMADO
  ENVIADO
  PENDIENTE_STOCK
  ENTREGADO
}

// ============================================================================
// USUARIOS Y AUTENTICACIÓN
// ============================================================================

model Usuario {
  id         Int      @id @default(autoincrement())
  nombre     String
  email      String   @unique
  password   String
  rol        Role
  activo     Boolean  @default(true)
  programa   Programa? @relation(fields: [programaId], references: [id])
  programaId Int?
  deposito   Deposito? @relation(fields: [depositoId], references: [id])
  depositoId Int?

  movimientos            Movimiento[]
  remitosChofer          Remito[]               @relation("RemitosChofer")
  relevamientos          RelevamientoNutricional[]
  programasTerreno       ProgramaTerreno[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([email])
  @@index([programaId])
  @@index([depositoId])
  @@index([rol])
}

// ============================================================================
// PROGRAMAS
// ============================================================================

model Programa {
  id             Int      @id @default(autoincrement())
  nombre         String   @unique
  descripcion    String?
  tipo           String   // REGULAR, PARTICULAR, DIARIO
  usaCronograma  Boolean  @default(false)
  usaPlantilla   Boolean  @default(true)
  descuentaStock Boolean  @default(true)
  activo            Boolean  @default(true)
  secretaria        String   @default("PA")
  mensajeWhatsapp   String?
  
  // Relaciones
  plantillas        Plantilla[]
  usuarios          Usuario[]
  beneficiarios     Beneficiario[]
  movimientos       Movimiento[]
  entregas          EntregaProgramada[]
  remitos           Remito[]
  tareas            Tarea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
}

// ============================================================================
// BENEFICIARIOS (ESPACIOS, COMEDORES, ORGANIZACIONES, CASOS PARTICULARES)
// ============================================================================

model Beneficiario {
  id                 Int      @id @default(autoincrement())
  nombre             String
  tipo               String   // ESPACIO, ORGANIZACION, CASO_PARTICULAR, COMEDOR
  direccion          String?
  localidad          String?
  telefono           String?
  responsableNombre  String?
  responsableDNI     String?
  lat                Float?
  lng                Float?
  frecuenciaEntrega  String?  // MENSUAL, BIMESTRAL, EVENTUAL
  kilosHabitual      Float?   // Kilos que recibe habitualmente este espacio
  activo             Boolean  @default(true)
  motivoBaja         String?  // FALLECIDO, MUDANZA, SUPERO_CRITERIOS, SOLICITUD_PROPIA, OTRO
  notaBaja           String?
  observaciones      String?
  
  // Programa al que pertenece
  programa           Programa? @relation(fields: [programaId], references: [id])
  programaId         Int?
  
  // Relaciones
  entregas           EntregaProgramada[]
  remitos            Remito[]
  movimientos        Movimiento[]
  documentos         DocumentoBeneficiario[]
  casos              Caso[]
  integrantes        IntegranteEspacio[]
  relevamientos      RelevamientoNutricional[]
  programasTerreno   ProgramaTerreno[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
  @@index([programaId])
  @@index([localidad])
  @@index([responsableDNI])
}

model DocumentoBeneficiario {
  id             Int          @id @default(autoincrement())
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id], onDelete: Cascade)
  beneficiarioId Int
  nombre         String       // Nombre descriptivo del documento
  archivo        String       // Nombre del archivo
  url            String       // URL en Supabase Storage o path local
  tipo           String?      // Tipo: DNI, INFORME, FOTO, OTRO
  estado         String       @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  createdAt      DateTime     @default(now())

  @@index([beneficiarioId])
}

model IntegranteEspacio {
  id             Int          @id @default(autoincrement())
  beneficiario   Beneficiario @relation(fields: [beneficiarioId], references: [id], onDelete: Cascade)
  beneficiarioId Int
  nombre         String
  dni            String?
  direccion      String?
  grupoFamiliar  Int?
  menores        Int?
  activo         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@index([beneficiarioId])
  @@index([dni])
}

// ============================================================================
// DEPÓSITOS (LOGISTICA Y CITA)
// ============================================================================

model Deposito {
  id        Int     @id @default(autoincrement())
  codigo    String  @unique    // 'LOGISTICA' | 'CITA'
  nombre    String
  direccion String?
  telefono  String?
  activo    Boolean @default(true)
  
  // Relaciones de stock
  stockItems Stock[]
  
  // Movimientos desde este depósito
  movimientosDesde Movimiento[] @relation("MovimientoDesde")
  
  // Movimientos hacia este depósito
  movimientosHacia Movimiento[] @relation("MovimientoHacia")
  
  // Remitos desde este depósito
  remitos  Remito[]

  // Entregas programadas asignadas a este depósito
  entregas EntregaProgramada[]

  // Usuarios asignados (LOGISTICA)
  usuarios Usuario[]
  lotes    LoteArticulo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([codigo])
}

// ============================================================================
// ARTÍCULOS E INVENTARIO
// ============================================================================

model Articulo {
  id             Int     @id @default(autoincrement())
  nombre         String  @unique
  descripcion    String?
  categoria      String?
  pesoUnitarioKg Float?  // Peso por unidad en kilogramos
  stockMinimo    Float?  // Alerta de stock mínimo
  fotoUrl        String? // URL de foto del artículo
  activo         Boolean @default(true)
  secretaria     String  @default("PA")

  // Relaciones
  plantillaItems PlantillaItem[]
  remitoItems    RemitoItem[]
  movimientos    Movimiento[]
  stockItems     Stock[]
  lotes          LoteArticulo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
  @@index([categoria])
}

model LoteArticulo {
  id               Int      @id @default(autoincrement())
  articulo         Articulo @relation(fields: [articuloId], references: [id], onDelete: Cascade)
  articuloId       Int
  deposito         Deposito @relation(fields: [depositoId], references: [id])
  depositoId       Int
  cantidad         Float
  fechaVencimiento DateTime
  lote             String?  // Número/código de lote (opcional)
  createdAt        DateTime @default(now())

  @@index([articuloId])
  @@index([depositoId])
  @@index([fechaVencimiento])
}

// ============================================================================
// STOCK POR DEPÓSITO
// ============================================================================

model Stock {
  id         Int      @id @default(autoincrement())
  articulo   Articulo @relation(fields: [articuloId], references: [id])
  articuloId Int
  deposito   Deposito @relation(fields: [depositoId], references: [id])
  depositoId Int
  cantidad   Float    @default(0)
  
  updatedAt DateTime @updatedAt

  @@unique([articuloId, depositoId])
  @@index([depositoId])
  @@index([articuloId])
}

// ============================================================================
// MOVIMIENTOS DE STOCK (TRAZABILIDAD COMPLETA)
// ============================================================================

model Movimiento {
  id              Int            @id @default(autoincrement())
  tipo            MovimientoTipo
  cantidad        Float
  observaciones   String?
  documentoUrl    String?        // Remito/factura adjunta al ingreso
  fecha           DateTime       @default(now())
  
  // Artículo
  articulo        Articulo       @relation(fields: [articuloId], references: [id])
  articuloId      Int
  
  // Usuario que realizó el movimiento
  usuario         Usuario?       @relation(fields: [usuarioId], references: [id])
  usuarioId       Int?
  
  // Programa asociado
  programa        Programa?      @relation(fields: [programaId], references: [id])
  programaId      Int?
  
  // Beneficiario asociado
  beneficiario    Beneficiario?  @relation(fields: [beneficiarioId], references: [id])
  beneficiarioId  Int?
  
  // Remito asociado
  remito          Remito?        @relation(fields: [remitoId], references: [id])
  remitoId        Int?
  
  // Depósito origen (para EGRESO y TRANSFERENCIA)
  depositoDesde   Deposito?      @relation("MovimientoDesde", fields: [depositoDesdeId], references: [id])
  depositoDesdeId Int?
  
  // Depósito destino (para INGRESO y TRANSFERENCIA)
  depositoHacia   Deposito?      @relation("MovimientoHacia", fields: [depositoHaciaId], references: [id])
  depositoHaciaId Int?

  @@index([fecha])
  @@index([tipo])
  @@index([articuloId])
  @@index([remitoId])
  @@index([programaId])
  @@index([usuarioId])
  @@index([beneficiarioId])
  @@index([depositoDesdeId])
  @@index([depositoHaciaId])
}

// ============================================================================
// PLANTILLAS DE ENTREGA
// ============================================================================

model Plantilla {
  id          Int             @id @default(autoincrement())
  nombre      String
  descripcion String?
  kilogramos  Float?          // Kilos de referencia para esta plantilla (ej: 300, 500, 1000)
  activo      Boolean         @default(true)
  
  // Programa al que pertenece
  programa    Programa        @relation(fields: [programaId], references: [id])
  programaId  Int
  
  // Items de la plantilla
  items       PlantillaItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programaId])
  @@index([activo])
}

model PlantillaItem {
  id           Int       @id @default(autoincrement())
  plantilla    Plantilla @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  plantillaId  Int
  articulo     Articulo  @relation(fields: [articuloId], references: [id])
  articuloId   Int
  cantidadBase Float     // Cantidad por defecto

  @@index([plantillaId])
  @@index([articuloId])
}

// ============================================================================
// CRONOGRAMA Y ENTREGAS PROGRAMADAS
// ============================================================================

model EntregaProgramada {
  id               Int           @id @default(autoincrement())
  beneficiario     Beneficiario  @relation(fields: [beneficiarioId], references: [id])
  beneficiarioId   Int
  programa         Programa?     @relation(fields: [programaId], references: [id])
  programaId       Int?
  fechaProgramada  DateTime
  estado           EntregaEstado @default(PENDIENTE)
  observaciones    String?
  hora             String?       // Ej: "10:30"
  responsableRetiro String?      // Nombre + DNI del responsable del retiro
  kilos            Float?        // Kilos estimados para esta entrega

  // Depósito seleccionado para esta entrega (antes de generar remito)
  deposito         Deposito?     @relation(fields: [depositoId], references: [id])
  depositoId       Int?

  // Remito generado (cuando pasa a GENERADA)
  remito           Remito?       @relation(fields: [remitoId], references: [id])
  remitoId         Int?          @unique

  // Secretaría
  secretaria       String        @default("PA")

  // Aviso WhatsApp
  avisadoWsp       Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([fechaProgramada])
  @@index([beneficiarioId])
  @@index([programaId])
  @@index([depositoId])
}

// ============================================================================
// REMITOS
// ============================================================================

model Remito {
  id              Int           @id @default(autoincrement())
  numero          String        @unique  // Formato: PA 1001649
  fecha           DateTime      @default(now())
  estado          RemitoEstado  @default(BORRADOR)
  totalKg         Float?
  observaciones   String?
  
  // Programa y Beneficiario
  programa        Programa?     @relation(fields: [programaId], references: [id])
  programaId      Int?
  beneficiario    Beneficiario? @relation(fields: [beneficiarioId], references: [id])
  beneficiarioId  Int?
  
  // Depósito de origen
  deposito        Deposito      @relation(fields: [depositoId], references: [id])
  depositoId      Int
  
  // Items del remito
  items           RemitoItem[]
  
  // Movimientos de stock generados
  movimientos     Movimiento[]
  
  // Entrega programada asociada (si existe)
  entrega         EntregaProgramada?

  // Caso particular que generó este remito (si aplica)
  caso            Caso?

  // Email enviado
  emailEnviado    Boolean       @default(false)
  fechaEnvio      DateTime?

  // Entrega física (retiro en depósito)
  entregadoAt    DateTime?
  entregadoNota  String?
  entregadoFoto  String?   // path relativo: uploads/remitos/foto.jpg

  // ── Entrega a domicilio ──
  esEntregaDomicilio  Boolean   @default(false)
  chofer              Usuario?  @relation("RemitosChofer", fields: [choferId], references: [id])
  choferId            Int?

  // Retiro del depósito por el chofer
  retiroDepositoAt    DateTime?
  retiroDepositoNota  String?   // quién retiró / observación

  // Firma del destinatario (entrega en domicilio)
  firmaDestinatario       String?   // imagen base64 de la firma
  nombreDestinatario      String?
  dniDestinatario         String?
  firmaDestinatarioAt     DateTime?

  // Secretaría
  secretaria     String        @default("PA")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([fecha])
  @@index([numero])
  @@index([beneficiarioId])
  @@index([programaId])
  @@index([depositoId])
  @@index([emailEnviado, estado])
  @@index([choferId])
  @@index([esEntregaDomicilio])
}

model RemitoItem {
  id         Int      @id @default(autoincrement())
  remito     Remito   @relation(fields: [remitoId], references: [id], onDelete: Cascade)
  remitoId   Int
  articulo   Articulo @relation(fields: [articuloId], references: [id])
  articuloId Int
  cantidad   Float
  pesoKg     Float?   // Peso total en kg (cantidad * pesoUnitario)

  @@index([remitoId])
  @@index([articuloId])
}

// ============================================================================
// CORRELATIVOS (para numeración de remitos)
// ============================================================================

model Correlativo {
  id     Int    @id @default(autoincrement())
  clave  String @unique  // 'remito_pa'
  ultimo Int    @default(1001648)
  
  updatedAt DateTime @updatedAt
}

// ============================================================================
// AUDITORÍA
// ============================================================================

model AuditoriaLog {
  id            Int      @id @default(autoincrement())
  usuarioId     Int?
  usuarioNombre String?
  metodo        String   // POST, PATCH, DELETE
  ruta          String   // URL path
  descripcion   String?  // Descripción human-readable
  datos         String?  // Snippet JSON del body (truncado)
  createdAt     DateTime @default(now())

  @@index([usuarioId])
  @@index([createdAt])
  @@index([ruta])
}

// ============================================================================
// TAREAS / PENDIENTES
// ============================================================================

model Tarea {
  id                  Int       @id @default(autoincrement())
  titulo              String
  descripcion         String?
  estado              String    @default("PENDIENTE") // PENDIENTE, EN_CURSO, COMPLETADA, CANCELADA
  prioridad           String    @default("MEDIA")     // BAJA, MEDIA, ALTA, URGENTE
  asignadoA           String?
  personal            Personal? @relation("TareaPersonal", fields: [personalId], references: [id])
  personalId          Int?
  secretaria          String    @default("PA")
  programa            Programa? @relation(fields: [programaId], references: [id])
  programaId          Int?
  vencimiento         DateTime?
  completadoAt        DateTime?
  completadoPorNombre String?
  completadoNota      String?
  archivos            ArchivoTarea[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  documentos          DocumentoTarea[]

  @@index([estado])
  @@index([programaId])
  @@index([personalId])
  @@index([createdAt])
}

model ArchivoTarea {
  id        Int      @id @default(autoincrement())
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  tareaId   Int
  nombre    String   // Nombre original del archivo
  url       String   // URL en Supabase Storage o path local
  tipo      String?  // MIME type (image/jpeg, application/pdf, etc.)
  createdAt DateTime @default(now())

  @@index([tareaId])
}

model DocumentoTarea {
  id        Int      @id @default(autoincrement())
  tarea     Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  tareaId   Int
  nombre    String
  archivo   String
  url       String
  tipo      String?
  createdAt DateTime @default(now())

  @@index([tareaId])
}

// ============================================================================
// PERSONAL (directorio de equipo)
// ============================================================================

model Personal {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String?
  cargo     String?  // Ej: "Logística", "Chofer", "Nutricionista", "Coordinador"
  email     String?
  activo    Boolean  @default(true)
  pushSubscription String? // Web Push subscription JSON
  tareas    Tarea[]  @relation("TareaPersonal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// ZONAS DEL MAPA
// ============================================================================

model Zona {
  id        Int      @id @default(autoincrement())
  nombre    String
  color     String   @default("#3388ff")
  geojson   String   // JSON: array de {lat, lng}
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// CASOS PARTICULARES (Trabajadoras Sociales + Asistencia Crítica)
// ============================================================================

enum CasoEstado {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
  RESUELTO
}

enum CasoPrioridad {
  NORMAL
  ALTA
  URGENTE
}

enum CasoTipo {
  ALIMENTARIO
  MERCADERIA
  MIXTO
}

model Caso {
  id                  Int           @id @default(autoincrement())

  // Datos del solicitante
  nombreSolicitante   String
  dni                 String?
  direccion           String?
  barrio              String?
  telefono            String?
  descripcion         String

  // Clasificación
  prioridad           CasoPrioridad @default(NORMAL)
  tipo                CasoTipo
  estado              CasoEstado    @default(PENDIENTE)

  // Auditoría de flujo
  notaRevision        String?
  revisadoAt          DateTime?

  // Quién lo creó
  creadoPorId         Int
  creadoPorNombre     String

  // Quién lo revisó
  revisadoPorId       Int?
  revisadoPorNombre   String?

  // Beneficiario vinculado (si ya existe en sistema)
  beneficiario        Beneficiario? @relation(fields: [beneficiarioId], references: [id])
  beneficiarioId      Int?

  // Remito generado al resolver
  remito              Remito?       @relation(fields: [remitoId], references: [id])
  remitoId            Int?          @unique

  // Alerta de cruce con otro programa
  alertaCruce         Boolean       @default(false)
  detalleCruce        String?

  documentos          DocumentoCaso[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([estado])
  @@index([prioridad])
  @@index([creadoPorId])
  @@index([dni])
  @@index([createdAt])
}

model DocumentoCaso {
  id        Int      @id @default(autoincrement())
  caso      Caso     @relation(fields: [casoId], references: [id], onDelete: Cascade)
  casoId    Int
  nombre    String
  archivo   String
  url       String
  tipo      String?
  createdAt DateTime @default(now())

  @@index([casoId])
}

// ============================================================================
// MÓDULO NUTRICIONISTA
// ============================================================================

enum ModalidadAlimentaria {
  RETIRAN_ALIMENTOS
  COMEN_EN_LUGAR
  MIXTO
}

enum EstadoGeneral {
  BUENO
  REGULAR
  MALO
}

enum TipoProgramaTerreno {
  HUERTA
  MANIPULACION_ALIMENTOS
  NUTRICION_INFANTIL
  CAPACITACION
  OTRO
}

enum EstadoProgramaTerreno {
  PLANIFICADO
  EN_CURSO
  FINALIZADO
  CANCELADO
}

model RelevamientoNutricional {
  id                  Int          @id @default(autoincrement())

  // Espacio/beneficiario relevado
  beneficiario        Beneficiario @relation(fields: [beneficiarioId], references: [id])
  beneficiarioId      Int

  // Nutricionista que hizo el relevamiento
  nutricionista       Usuario      @relation(fields: [nutricionistaId], references: [id])
  nutricionistaId     Int

  fecha               DateTime     @default(now())

  // Población
  poblacionInfantil05 Int?         // Niños 0-5 años
  poblacionInfantil612 Int?        // Niños 6-12 años
  poblacionAdolescente Int?        // 13-17 años
  poblacionAdulta     Int?         // 18+

  // Modalidad alimentaria del espacio
  modalidad           ModalidadAlimentaria?

  // Infraestructura
  tieneCocina         Boolean      @default(false)
  aguaPotable         Boolean      @default(false)
  tieneHeladera       Boolean      @default(false)

  // Evaluación
  estadoGeneral       EstadoGeneral?
  necesidades         String?      // Texto libre: qué necesitan
  observaciones       String?      // Observaciones generales

  // Fotos del relevamiento (JSON array de URLs)
  fotos               String?      // JSON: ["url1", "url2"]

  // Enfermedades crónicas reportadas en el espacio
  enfermedadesCronicas        String?  // JSON: ["OBESIDAD","DIABETES_T1","DIABETES_T2",...]

  // Asistencias especiales que recibe el espacio
  asistenciasEspeciales       String?  // JSON: ["CELIAQUIA","DISCAPACIDAD","OTRO"]
  asistenciasEspecialesDetalle String?

  // Recibe alimentos de otra red
  recibeOtraRed               Boolean  @default(false)
  otraRedDetalle              String?

  // Agua corriente (diferente de agua potable — puede haber agua corriente no potable)
  aguaCorriente               Boolean  @default(false)

  // Sugerencias nutricionales
  alimentosIntegrar           String?
  alimentosModificar          String?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([beneficiarioId])
  @@index([nutricionistaId])
  @@index([fecha])
}

model ProgramaTerreno {
  id                Int          @id @default(autoincrement())

  // Tipo de programa/curso
  tipo              TipoProgramaTerreno
  nombre            String?      // Nombre personalizado (ej: "Huerta primavera 2026")
  descripcion       String?

  // Espacio donde se ejecuta
  beneficiario      Beneficiario @relation(fields: [beneficiarioId], references: [id])
  beneficiarioId    Int

  // Nutricionista responsable
  nutricionista     Usuario      @relation(fields: [nutricionistaId], references: [id])
  nutricionistaId   Int

  // Fechas y duración
  fechaInicio       DateTime
  fechaFin          DateTime?
  duracionSemanas   Int?

  estado            EstadoProgramaTerreno @default(PLANIFICADO)

  // Actividades realizadas dentro de este programa
  actividades       ActividadTerreno[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([beneficiarioId])
  @@index([nutricionistaId])
  @@index([estado])
  @@index([fechaInicio])
}

model ActividadTerreno {
  id                Int              @id @default(autoincrement())

  // Programa al que pertenece
  programaTerreno   ProgramaTerreno  @relation(fields: [programaTerrenoId], references: [id], onDelete: Cascade)
  programaTerrenoId Int

  fecha             DateTime         @default(now())
  descripcion       String
  asistentes        Int?             // Cantidad de asistentes
  observaciones     String?

  // Fotos/archivos (JSON array de URLs)
  fotos             String?          // JSON: ["url1", "url2"]

  // Documentos adjuntos (fotos, PDFs, etc.)
  documentos        String?          // JSON: [{url, nombre, tipo}]

  createdAt         DateTime         @default(now())

  @@index([programaTerrenoId])
  @@index([fecha])
}

model NotaBorrador {
  id        Int      @id @default(autoincrement())
  clave     String   @unique // ej: "cronograma"
  contenido String   @default("")
  updatedAt DateTime @updatedAt
}

// ============================================================================
// DOCUMENTOS (repositorio central de documentación)
// ============================================================================

model Documento {
  id              Int      @id @default(autoincrement())
  nombre          String                                // título descriptivo
  archivo         String                                // filename original
  url             String                                // URL pública (Supabase) o path local
  categoria       String   @default("OTRO")             // REMITOS | BENEFICIARIOS | RENDICIONES | NORMATIVA | MODELOS | OTRO
  descripcion     String?                               // texto libre
  tipo            String?                               // MIME (application/pdf, image/jpeg, etc.)
  tamanioBytes    Int?
  secretaria      String   @default("PA")
  subidoPorId     Int?
  subidoPorNombre String?
  createdAt       DateTime @default(now())

  @@index([categoria])
  @@index([secretaria])
  @@index([createdAt])
}
