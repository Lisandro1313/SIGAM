# ============================================================
# SIGAM - Variables de entorno
# Copiá este archivo a .env y completá los valores reales
# NUNCA commitear el .env al repositorio
# ============================================================

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://USUARIO:CONTRASENA@localhost:5432/sigam?schema=public"

# JWT - Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIAR_POR_SECRETO_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=production

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# EMAIL - Gmail con App Password
# Ver: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu_email@gmail.com"
SMTP_PASSWORD="xxxx xxxx xxxx xxxx"
SMTP_FROM="Inclusion Social <tu_email@gmail.com>"

# Emails destino de los remitos
DEPOSITO_EMAIL_LOGISTICA="email_logistica@gmail.com"
DEPOSITO_EMAIL_CITA="email_cita@gmail.com"

# Archivos
MAX_FILE_SIZE=10485760
