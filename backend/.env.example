# ============================================================
# SIGAM - Variables de entorno
# Copiá este archivo a .env y completá los valores reales
# NUNCA commitear el .env al repositorio
# ============================================================

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://USUARIO:CONTRASENA@localhost:5432/sigam?schema=public"

# JWT - Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIAR_POR_SECRETO_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=production

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# Resend — obtené tu API key en https://resend.com
RESEND_API_KEY="re_REEMPLAZAR_CON_API_KEY"
RESEND_FROM="Política Alimentaria <onboarding@resend.dev>"

# Emails destino de los remitos
DEPOSITO_EMAIL_LOGISTICA="logistica.deposito.5231@gmail.com"
DEPOSITO_EMAIL_CITA="citadeposito@gmail.com"

# Archivos
MAX_FILE_SIZE=10485760
